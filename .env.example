# Variables de entorno para Timer Cuarto de Chenz

# Configuración de Twitch
VITE_TWITCH_CHANNEL=brunispet
VITE_TWITCH_USERNAME=brunispet_bot
VITE_TWITCH_TOKEN=oauth:your_twitch_oauth_token_here

# Configuración de Discord Webhook
VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token_here

# Nota: Copia este archivo a .env y reemplaza los valores con tus credenciales reales
# Nunca compartas tu archivo .env ni lo subas al repositorio
